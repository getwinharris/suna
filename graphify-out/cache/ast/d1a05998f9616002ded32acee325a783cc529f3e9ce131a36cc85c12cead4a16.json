sessionId);\n    } catch {\n      // Non-critical \u2014 cache is still warm from IDB\n    }\n  })", "is_member_call": false, "source_file": "/Users/getwinharris/Dev/suna-bapx/apps/web/src/hooks/opencode/use-session-prefetch.ts", "source_location": "L25"}, {"caller_nid": "opencode_use_session_prefetch_prefetchsession", "callee": "set", "is_member_call": true, "source_file": "/Users/getwinharris/Dev/suna-bapx/apps/web/src/hooks/opencode/use-session-prefetch.ts", "source_location": "L65"}, {"caller_nid": "opencode_use_session_prefetch_resetprefetchstate", "callee": "clear", "is_member_call": true, "source_file": "/Users/getwinharris/Dev/suna-bapx/apps/web/src/hooks/opencode/use-session-prefetch.ts", "source_location": "L73"}, {"caller_nid": "opencode_use_session_prefetch_resetprefetchstate", "callee": "clear", "is_member_call": true, "source_file": "/Users/getwinharris/Dev/suna-bapx/apps/web/src/hooks/opencode/use-session-prefetch.ts", "source_location": "L74"}, {"caller_nid": "opencode_use_session_prefetch_usebackgroundsessionprefetch", "callee": "useEffect", "is_member_call": false, "source_file": "/Users/getwinharris/Dev/suna-bapx/apps/web/src/hooks/opencode/use-session-prefetch.ts", "source_location": "L82"}, {"caller_nid": "opencode_use_session_prefetch_usebackgroundsessionprefetch", "callee": "useCallback", "is_member_call": false, "source_file": "/Users/getwinharris/Dev/suna-bapx/apps/web/src/hooks/opencode/use-session-prefetch.ts", "source_location": "L87"}]}