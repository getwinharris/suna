# Bapx Media Hub TrailBase Configuration
email {}
server {
  application_name: "Bapx Media Hub"
  logs_retention_sec: 604800
}
auth {
  auth_token_ttl_sec: 3600
  refresh_token_ttl_sec: 2592000
}

record_apis: [
  {
    name: "accounts"
    table_name: "accounts"
    acl_authenticated: [READ, CREATE, UPDATE, DELETE]
    autofill_missing_user_id_columns: false
  },
  {
    name: "account_members"
    table_name: "account_members"
    acl_authenticated: [READ, CREATE, UPDATE, DELETE]
  },
  {
    name: "platform_user_roles"
    table_name: "platform_user_roles"
    acl_authenticated: [READ, CREATE, UPDATE, DELETE]
    autofill_missing_user_id_columns: false
  },
  {
    name: "sandboxes"
    table_name: "sandboxes"
    acl_authenticated: [READ, CREATE, UPDATE, DELETE]
  },
  {
    name: "sandbox_members"
    table_name: "sandbox_members"
    acl_authenticated: [READ, CREATE, UPDATE, DELETE]
  },
  {
